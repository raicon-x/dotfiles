# Color theme
#theme = tokyonight
theme = Catppuccin Mocha

# Font
font-family = JetBrains Mono

# Cursor
cursor-style = block
# cursor-color = #ffcccc

# Background
# background = #1a1b26
# background = #222436
background-opacity = 0.8
background-blur = true

# Keybindings
keybind = super+u=scroll_page_up
keybind = super+d=scroll_page_down
keybind = super+k=scroll_page_lines:3
keybind = super+j=scroll_page_lines:-3
keybind = super+\=new_split:down
keybind = super+shift+\=new_split:right
keybind = ctrl+t=next_tab
keybind = ctrl+shift+t=previous_tab


